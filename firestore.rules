rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /questions/{questionId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
