{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "scripts/**",
      "docs/**",
      "progress.md",
      "CLAUDE.md",
      "*.pdf"
    ],
    "rewrites": [
      {
        "source": "/admin",
        "destination": "/admin/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
